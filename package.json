{
  "name": "editor-llm",
  "version": "1.0.0",
  "description": "EditorLLM \u2014 AI-augmented book editing workspace for Google Docs",
  "main": "dist/Code.js",
  "type": "commonjs",
  "scripts": {
    "build": "rm -rf dist && tsc && node scripts/fixgas.js && cp appsscript.json dist/ && cp *.html dist/ 2>/dev/null || true",
    "lint": "eslint src/**/*.ts",
    "test": "npm run build && jest --config config/jest/jest.config.cjs",
    "test:experimental": "npm run build && jest --config config/jest/jest.experimental.config.cjs",
    "test:integration": "jest --config config/jest/jest.integration.config.cjs 2>&1 | tee .last_integration_test_results.txt",
    "test:e2e": "jest --config config/jest/jest.e2e.config.cjs && jest --config config/jest/jest.e2e-serial.config.cjs",
    "test:e2e-parallel": "jest --config config/jest/jest.e2e.config.cjs 2>&1 | tee .last_e2e_test_results.txt",
    "test:e2e-serial": "jest --config config/jest/jest.e2e-serial.config.cjs 2>&1 | tee .last_e2e_serial_test_results.txt",
    "build:all": "npm run build && npm run lint && npm run test",
    "deploy:staging": "bash scripts/deploy.sh --skip-e2e",
    "deploy:prod": "npm run build:all && clasp deploy --deploymentId AKfycbwb1ZcM2nmBtN2YVY5cIofl3X__Cdtln912ZC3nOxC5cpMB_Gm-OH-jkIoJWwNZW0XI",
    "dump_prompts": "node scripts/dump_prompts.js",
    "postbuild": "npm run dump_prompts"
  },
  "devDependencies": {
    "@types/google-apps-script": "^1.0.83",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.2",
    "@types/xmlhttprequest": "^1.8.2",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "^10.2.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.3.2",
    "typescript": "^5.8.3",
    "xmlhttprequest": "^1.8.0"
  }
}
