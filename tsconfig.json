{
  "compilerOptions": {
    "target": "ES2019",
    "module": "none",
    "rootDir": "src",
    "outDir": "dist",
    "lib": ["es2019", "dom"],
    "types": ["google-apps-script", "jest", "node"],
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmitOnError": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", "src/__tests__/**/*", "src/experimental/**/*", "jest.setup.ts"]
}
